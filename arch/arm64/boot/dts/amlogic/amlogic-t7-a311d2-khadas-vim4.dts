/dts-v1/;

#include <dt-bindings/clock/amlogic,t7-peripherals-clkc.h>
#include <dt-bindings/gpio/amlogic,t7-periphs-pinctrl.h>
#include <dt-bindings/gpio/gpio.h>
#include "amlogic-t7.dtsi"

/ {
	model = "Khadas VIM4";
	compatible = "khadas,vim4", "amlogic,a311d2", "amlogic,t7";

	aliases {
		ethernet0 = &ethmac;
		serial0 = &uart_a;
		mmc0 = &sd_emmc_c;
		mmc1 = &sd_emmc_b;
	};

	chosen {
		stdout-path = "serial0:921600n8";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x0 0x0 0xE0000000
			0x1 0x0 0x0 0xE0000000
			0x2 0x0 0x0 0x40000000>; /* 8 GB */
		linux,usable-memory = <0x0 0x0 0x0 0xE0000000
				       0x1 0x0 0x0 0xE0000000
				       0x2 0x0 0x0 0x40000000>;
	};

	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		ramoops@8400000 {
			compatible = "ramoops";
			reg = <0x0 0x08400000 0x0 0x00100000>;
			record-size = <0x20000>;
			console-size = <0x40000>;
			ftrace-size = <0x80000>;
			pmsg-size = <0x20000>;
		};

		logo_reserved: linux,meson-fb {
			compatible = "amlogic, meson-fb";
			reusable;
			size = <0x0 0x00800000>;
			alignment = <0x0 0x00400000>;
			reg = <0x0 0x3f800000 0x0 0x00800000>;
		};

		/* Vendor U-Boot hardcodes this node path during rsvmem check. */
		secmon_reserved: linux,secmon {
			compatible = "shared-dma-pool";
			no-map;
			size = <0x0 0x03400000>;
			alignment = <0x0 0x00400000>;
			alloc-ranges = <0x0 0x05000000 0x0 0x03400000>;
		};
	};

	partitions: partitions {
		parts = <1>;
		part-0 = <&rootfs>;

		rootfs: rootfs {
			pname = "rootfs";
			size = <0xffffffff 0xffffffff>;
			mask = <4>;
		};
	};

	secmon {
		compatible = "amlogic, secmon";
		memory-region = <&secmon_reserved>;
		in_base_func = <0x82000020>;
		out_base_func = <0x82000021>;
		inout_size_func = <0x8200002a>;
		reserve_mem_size = <0x03300000>;
	};

	xtal: xtal-clk {
		compatible = "fixed-clock";
		clock-frequency = <24000000>;
		clock-output-names = "xtal";
		#clock-cells = <0>;
	};

	/* Temporary parent clocks until the full T7 SCMI/PLL map is safe to enable. */
	sys_clk: sys-clk {
		compatible = "fixed-clock";
		clock-frequency = <166666666>;
		clock-output-names = "sys";
		#clock-cells = <0>;
	};

	fixed_pll: fixed-pll-clk {
		compatible = "fixed-clock";
		clock-frequency = <2000000000>;
		clock-output-names = "fix";
		#clock-cells = <0>;
	};

	fdiv2: fdiv2-clk {
		compatible = "fixed-clock";
		clock-frequency = <1000000000>;
		clock-output-names = "fdiv2";
		#clock-cells = <0>;
	};

	fdiv2p5: fdiv2p5-clk {
		compatible = "fixed-clock";
		clock-frequency = <800000000>;
		clock-output-names = "fdiv2p5";
		#clock-cells = <0>;
	};

	fdiv3: fdiv3-clk {
		compatible = "fixed-clock";
		clock-frequency = <666666666>;
		clock-output-names = "fdiv3";
		#clock-cells = <0>;
	};

	fdiv4: fdiv4-clk {
		compatible = "fixed-clock";
		clock-frequency = <500000000>;
		clock-output-names = "fdiv4";
		#clock-cells = <0>;
	};

	fdiv5: fdiv5-clk {
		compatible = "fixed-clock";
		clock-frequency = <400000000>;
		clock-output-names = "fdiv5";
		#clock-cells = <0>;
	};

	fdiv7: fdiv7-clk {
		compatible = "fixed-clock";
		clock-frequency = <285714285>;
		clock-output-names = "fdiv7";
		#clock-cells = <0>;
	};

	hifi: hifi-clk {
		compatible = "fixed-clock";
		clock-frequency = <500000000>;
		clock-output-names = "hifi";
		#clock-cells = <0>;
	};

	gp0: gp0-clk {
		compatible = "fixed-clock";
		clock-frequency = <1000000000>;
		clock-output-names = "gp0";
		#clock-cells = <0>;
	};

	gp1: gp1-clk {
		compatible = "fixed-clock";
		clock-frequency = <1000000000>;
		clock-output-names = "gp1";
		#clock-cells = <0>;
	};

	mpll1: mpll1-clk {
		compatible = "fixed-clock";
		clock-frequency = <500000000>;
		clock-output-names = "mpll1";
		#clock-cells = <0>;
	};

	mpll2: mpll2-clk {
		compatible = "fixed-clock";
		clock-frequency = <500000000>;
		clock-output-names = "mpll2";
		#clock-cells = <0>;
	};

	mpll_50m: mpll-50m-clk {
		compatible = "fixed-clock";
		clock-frequency = <50000000>;
		clock-output-names = "mpll_50m";
		#clock-cells = <0>;
	};

	vddao_3v3: regulator-vddao-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "VDDAO_3V3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
	};

	vdd_mali: regulator-vdd-mali {
		compatible = "regulator-fixed";
		regulator-name = "VDD_MALI";
		regulator-min-microvolt = <1150000>;
		regulator-max-microvolt = <1150000>;
		regulator-always-on;
	};

	vddio_1v8: regulator-vddio-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "VDDIO_1V8";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-always-on;
	};

	sdcard_power: regulator-sdcard-power {
		compatible = "regulator-fixed";
		regulator-name = "SDCARD_POWER";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpio = <&gpio GPIOD_11 GPIO_ACTIVE_LOW>;
		regulator-boot-on;
	};

	vddio_card: regulator-vddio-card {
		compatible = "regulator-gpio";
		regulator-name = "VDDIO_CARD";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpios = <&gpio GPIOD_9 GPIO_ACTIVE_HIGH>;
		gpios-states = <0>;
		states = <1800000 1>,
			 <3300000 0>;
		regulator-boot-on;
	};

	usb_power: regulator-usb-power {
		compatible = "regulator-fixed";
		regulator-name = "USB_POWER";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		gpio = <&gpio GPIOY_5 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		regulator-boot-on;
	};

};

&{/} {
	thermal-zones {
		a73_thermal: a73-thermal {
			polling-delay = <1000>;
			polling-delay-passive = <100>;
			thermal-sensors = <&a73_temp>;

			trips {
				a73_passive: a73-passive {
					temperature = <85000>;
					hysteresis = <2000>;
					type = "passive";
				};

				a73_hot: a73-hot {
					temperature = <95000>;
					hysteresis = <2000>;
					type = "hot";
				};

				a73_critical: a73-critical {
					temperature = <110000>;
					hysteresis = <2000>;
					type = "critical";
				};
			};
		};

		a53_thermal: a53-thermal {
			polling-delay = <1000>;
			polling-delay-passive = <100>;
			thermal-sensors = <&a53_temp>;

			trips {
				a53_passive: a53-passive {
					temperature = <85000>;
					hysteresis = <2000>;
					type = "passive";
				};

				a53_hot: a53-hot {
					temperature = <95000>;
					hysteresis = <2000>;
					type = "hot";
				};

				a53_critical: a53-critical {
					temperature = <110000>;
					hysteresis = <2000>;
					type = "critical";
				};
			};
		};
	};

	gpu: gpu@fe400000 {
		compatible = "amlogic,meson-t7-mali", "arm,mali-bifrost";
		reg = <0x0 0xfe400000 0x0 0x4000>;
		interrupt-parent = <&gic>;
		interrupts = <GIC_SPI 146 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 145 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 144 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "job", "mmu", "gpu";
		clocks = <&clkc_periphs CLKID_MALI>;
		mali-supply = <&vdd_mali>;
		operating-points-v2 = <&gpu_opp_table>;
		power-domains = <&pwrc PWRC_T7_MALI_TOP_ID>;
		resets = <&reset RESET_MALI_CAPB3>, <&reset RESET_MALI>;
		#cooling-cells = <2>;

		assigned-clocks = <&clkc_periphs CLKID_MALI_0_SEL>,
				  <&clkc_periphs CLKID_MALI_0>,
				  <&clkc_periphs CLKID_MALI>;
		assigned-clock-parents = <&fdiv2p5>,
					 <0>,
					 <&clkc_periphs CLKID_MALI_0>;
		assigned-clock-rates = <0>, <800000000>, <0>;
		status = "okay";
	};
};

&apb4 {
	clkc_periphs: clock-controller@0 {
		compatible = "amlogic,t7-peripherals-clkc";
		reg = <0x0 0x0 0x0 0x1c8>;
		#clock-cells = <1>;
		clocks = <&xtal>,
			 <&sys_clk>,
			 <&fixed_pll>,
			 <&fdiv2>,
			 <&fdiv2p5>,
			 <&fdiv3>,
			 <&fdiv4>,
			 <&fdiv5>,
			 <&fdiv7>,
			 <&hifi>,
			 <&gp0>,
			 <&gp1>,
			 <&mpll1>,
			 <&mpll2>;
		clock-names = "xtal",
			      "sys",
			      "fix",
			      "fdiv2",
			      "fdiv2p5",
			      "fdiv3",
			      "fdiv4",
			      "fdiv5",
			      "fdiv7",
			      "hifi",
			      "gp0",
			      "gp1",
			      "mpll1",
			      "mpll2";
	};

	eth_phy: mdio-multiplexer@28000 {
		compatible = "amlogic,g12a-mdio-mux";
		reg = <0x0 0x28000 0x0 0xa4>;
		clocks = <&clkc_periphs CLKID_SYS_ETHPHY>,
			 <&xtal>,
			 <&mpll_50m>;
		clock-names = "pclk", "clkin0", "clkin1";
		mdio-parent-bus = <&mdio0>;
		#address-cells = <1>;
		#size-cells = <0>;

		ext_mdio: mdio@0 {
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <0>;

			external_phy: ethernet-phy@0 {
				reg = <0>;
				max-speed = <1000>;
				reset-assert-us = <20000>;
				reset-deassert-us = <50000>;
			};
		};
	};
};

&periphs_pinctrl {
	eth_pins: eth-pins {
		mux {
			groups = "eth_mdio",
				 "eth_mdc",
				 "eth_rgmii_rx_clk",
				 "eth_rx_dv",
				 "eth_rxd0",
				 "eth_rxd1",
				 "eth_txen",
				 "eth_txd0",
				 "eth_txd1";
			function = "eth";
			bias-disable;
			drive-strength-microamp = <4000>;
		};
	};

	eth_rgmii_pins: eth-rgmii-pins {
		mux {
			groups = "eth_rxd2_rgmii",
				 "eth_rxd3_rgmii",
				 "eth_rgmii_tx_clk",
				 "eth_txd2_rgmii",
				 "eth_txd3_rgmii";
			function = "eth";
			bias-disable;
			drive-strength-microamp = <4000>;
		};
	};

	sdcard_pins: sdcard-pins {
		mux {
			groups = "sdcard_d0",
				 "sdcard_d1",
				 "sdcard_d2",
				 "sdcard_d3",
				 "sdcard_cmd";
			function = "sdcard";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};

		mux-clk {
			groups = "sdcard_clk";
			function = "sdcard";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};
	};

	sdcard_clk_gate_pins: sdcard-clk-gate-pins {
		mux {
			groups = "GPIOC_4";
			function = "gpio_periphs";
			bias-pull-down;
			drive-strength-microamp = <4000>;
		};
	};

	emmc_pins: emmc-pins {
		mux {
			groups = "emmc_nand_d0",
				 "emmc_nand_d1",
				 "emmc_nand_d2",
				 "emmc_nand_d3",
				 "emmc_nand_d4",
				 "emmc_nand_d5",
				 "emmc_nand_d6",
				 "emmc_nand_d7",
				 "emmc_cmd";
			function = "emmc";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};
	};

	emmc_clk_pins: emmc-clk-pins {
		mux {
			groups = "emmc_clk";
			function = "emmc";
			bias-disable;
			drive-strength-microamp = <4000>;
		};
	};

	emmc_ds_pins: emmc-ds-pins {
		mux {
			groups = "emmc_nand_ds";
			function = "emmc";
			bias-pull-down;
			drive-strength-microamp = <4000>;
		};
	};

	emmc_clk_gate_pins: emmc-clk-gate-pins {
		mux {
			groups = "GPIOB_8";
			function = "gpio_periphs";
			bias-pull-down;
			drive-strength-microamp = <4000>;
		};
	};
};

&{/soc} {
	a73_temp: temperature-sensor@fe020000 {
		compatible = "amlogic,t7-thermal";
		reg = <0x0 0xfe020000 0x0 0x50>;
		interrupts = <GIC_SPI 31 IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&clkc_periphs CLKID_TS>;
		assigned-clocks = <&clkc_periphs CLKID_TS>;
		assigned-clock-rates = <500000>;
		#thermal-sensor-cells = <0>;
		amlogic,thermal-sensor-id = <1>;
		secure-monitor = <&sm>;
	};

	a53_temp: temperature-sensor@fe022000 {
		compatible = "amlogic,t7-thermal";
		reg = <0x0 0xfe022000 0x0 0x50>;
		interrupts = <GIC_SPI 30 IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&clkc_periphs CLKID_TS>;
		assigned-clocks = <&clkc_periphs CLKID_TS>;
		assigned-clock-rates = <500000>;
		#thermal-sensor-cells = <0>;
		amlogic,thermal-sensor-id = <2>;
		secure-monitor = <&sm>;
	};

	ethmac: ethernet@fdc00000 {
		compatible = "amlogic,meson-g12a-dwmac",
			     "snps,dwmac-4.00",
			     "snps,dwmac";
		reg = <0x0 0xfdc00000 0x0 0x10000>,
		      <0x0 0xfe024000 0x0 0x8>;
		interrupts = <GIC_SPI 74 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "macirq";
		clocks = <&clkc_periphs CLKID_SYS_ETH>,
			 <&fdiv2>,
			 <&mpll2>;
		clock-names = "stmmaceth", "clkin0", "clkin1";
		power-domains = <&pwrc PWRC_T7_ETH_ID>;
		pinctrl-0 = <&eth_pins>, <&eth_rgmii_pins>;
		pinctrl-names = "default";
		phy-mode = "rgmii";
		phy-handle = <&external_phy>;
		amlogic,tx-delay-ns = <2>;
		rx-internal-delay-ps = <2000>;
		internal_phy = <2>;
		mc_val = <0x1621>;
		cali_val = <0xa0000>;
		rx-fifo-depth = <4096>;
		tx-fifo-depth = <2048>;
		status = "okay";

		mdio0: mdio {
			compatible = "snps,dwmac-mdio";
			#address-cells = <1>;
			#size-cells = <0>;
		};
	};

	usb2_phy0: phy@fe03c000 {
		compatible = "amlogic,g12a-usb2-phy";
		reg = <0x0 0xfe03c000 0x0 0x2000>;
		clocks = <&xtal>;
		clock-names = "xtal";
		resets = <&reset RESET_U2PHY20>;
		reset-names = "phy";
		power-domains = <&pwrc PWRC_T7_USB_COMB_ID>;
		phy-supply = <&usb_power>;
		#phy-cells = <0>;
	};

	usb2_phy1: phy@fe03e000 {
		compatible = "amlogic,g12a-usb2-phy";
		reg = <0x0 0xfe03e000 0x0 0x2000>;
		clocks = <&xtal>;
		clock-names = "xtal";
		resets = <&reset RESET_U2PHY21>;
		reset-names = "phy";
		power-domains = <&pwrc PWRC_T7_USB_COMB_ID>;
		#phy-cells = <0>;
	};

	usb: usb@fe03a000 {
		compatible = "amlogic,meson-g12a-usb-ctrl";
		reg = <0x0 0xfe03a000 0x0 0xa0>;
		interrupts = <GIC_SPI 129 IRQ_TYPE_EDGE_RISING>;
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		clocks = <&clkc_periphs CLKID_SYS_USB>;
		resets = <&reset RESET_USB>;
		power-domains = <&pwrc PWRC_T7_USB_COMB_ID>;

		dr_mode = "host";

		phys = <&usb2_phy0>, <&usb2_phy1>;
		phy-names = "usb2-phy0", "usb2-phy1";

		xhci2: usb@fdd00000 {
			compatible = "amlogic,t7-crg-xhci", "generic-xhci";
			reg = <0x0 0xfdd00000 0x0 0x8000>;
			interrupts = <GIC_SPI 131 IRQ_TYPE_EDGE_RISING>;
			clocks = <&clkc_periphs CLKID_SYS_USB>;
			clock-names = "core";
			dr_mode = "host";
			usb2-lpm-disable;
		};

		xhci3: usb@fde00000 {
			compatible = "amlogic,t7-crg-xhci", "generic-xhci";
			reg = <0x0 0xfde00000 0x0 0x8000>;
			interrupts = <GIC_SPI 130 IRQ_TYPE_EDGE_RISING>;
			clocks = <&clkc_periphs CLKID_SYS_USB>;
			clock-names = "core";
			dr_mode = "host";
			usb2-lpm-disable;
		};
	};

	sd_emmc_b: mmc@fe08a000 {
		compatible = "amlogic,t7-mmc", "amlogic,meson-axg-mmc";
		reg = <0x0 0xfe08a000 0x0 0x800>;
		interrupts = <GIC_SPI 177 IRQ_TYPE_EDGE_RISING>;
		clocks = <&clkc_periphs CLKID_SYS_SD_EMMC_B>,
			 <&clkc_periphs CLKID_SD_EMMC_B>,
			 <&fdiv2>;
		clock-names = "core", "clkin0", "clkin1";
		resets = <&reset RESET_SD_EMMC_B>;
		power-domains = <&pwrc PWRC_T7_SDIO_B_ID>;
		pinctrl-0 = <&sdcard_pins>;
		pinctrl-1 = <&sdcard_clk_gate_pins>;
		pinctrl-names = "default", "clk-gate";
		bus-width = <4>;
		cap-sd-highspeed;
		max-frequency = <50000000>;
		assigned-clocks = <&clkc_periphs CLKID_SD_EMMC_B>;
		assigned-clock-rates = <24000000>;
		disable-wp;
		no-mmc;
		no-sdio;
		cd-gpios = <&gpio GPIOC_6 GPIO_ACTIVE_HIGH>;
		vmmc-supply = <&sdcard_power>;
		vqmmc-supply = <&vddio_card>;
		status = "okay";
	};

	sd_emmc_c: mmc@fe08c000 {
		compatible = "amlogic,t7-mmc", "amlogic,meson-axg-mmc";
		reg = <0x0 0xfe08c000 0x0 0x800>;
		interrupts = <GIC_SPI 178 IRQ_TYPE_EDGE_RISING>;
		clocks = <&clkc_periphs CLKID_SYS_SD_EMMC_C>,
			 <&clkc_periphs CLKID_SD_EMMC_C>,
			 <&fdiv2>;
		clock-names = "core", "clkin0", "clkin1";
		resets = <&reset RESET_SD_EMMC_C>;
		power-domains = <&pwrc PWRC_T7_EMMC_ID>;
		pinctrl-0 = <&emmc_pins>, <&emmc_clk_pins>, <&emmc_ds_pins>;
		pinctrl-1 = <&emmc_clk_gate_pins>;
		pinctrl-names = "default", "clk-gate";
		bus-width = <8>;
		cap-mmc-highspeed;
		max-frequency = <50000000>;
		assigned-clocks = <&clkc_periphs CLKID_SD_EMMC_C>;
		assigned-clock-rates = <24000000>;
		non-removable;
		disable-wp;
		no-sd;
		no-sdio;
		vmmc-supply = <&vddao_3v3>;
		vqmmc-supply = <&vddio_1v8>;
		status = "okay";
	};
};

&drm_subsystem {
	memory-region = <&logo_reserved>;
};

&uart_a {
	status = "okay";
	clocks = <&xtal>, <&xtal>, <&xtal>;
	clock-names = "xtal", "pclk", "baud";
};
