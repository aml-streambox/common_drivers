// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
/*
 * Minimal Linux v7.1 TVPRO bring-up device tree.
 *
 * This intentionally starts from upstream T7 support and only carries the
 * board data needed before enabling the 5.15 vendor multimedia stack.
 */

/dts-v1/;

#include <dt-bindings/clock/amlogic,t7-peripherals-clkc.h>
#include <dt-bindings/gpio/amlogic,t7-periphs-pinctrl.h>
#include <dt-bindings/gpio/gpio.h>
#include "amlogic-t7.dtsi"

/ {
	model = "CoreLab A311D2-TVPro";
	compatible = "corelab,a311d2-tvpro", "amlogic,a311d2", "amlogic,t7";

	aliases {
		ethernet0 = &ethmac;
		serial0 = &uart_a;
		serial1 = &uart_c;
		mmc0 = &sd_emmc_c;
		mmc1 = &sd_emmc_b;
		mmc2 = &sd_emmc_a;
	};

	chosen {
		stdout-path = "serial0:921600n8";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x0 0x0 0xe0000000
		       0x1 0x0 0x0 0xe0000000
		       0x2 0x0 0x0 0x40000000>; /* 8 GB */
		linux,usable-memory = <0x0 0x0 0x0 0xe0000000
				       0x1 0x0 0x0 0xe0000000
				       0x2 0x0 0x0 0x40000000>;
	};

	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		ramoops@8400000 {
			compatible = "ramoops";
			reg = <0x0 0x08400000 0x0 0x00100000>;
			record-size = <0x20000>;
			console-size = <0x40000>;
			ftrace-size = <0x80000>;
			pmsg-size = <0x20000>;
		};

		logo_reserved: linux,meson-fb {
			compatible = "amlogic, meson-fb";
			reusable;
			size = <0x0 0x00800000>;
			alignment = <0x0 0x00400000>;
			reg = <0x0 0x3f800000 0x0 0x00800000>;
		};

		codec_mm_cma: linux,codec_mm_cma {
			compatible = "shared-dma-pool";
			reusable;
			size = <0x0 0x40000000>;
			alignment = <0x0 0x00400000>;
			linux,contiguous-region;
			alloc-ranges = <0x0 0x0 0x0 0xe0000000>;
			clear-map;
		};

		vdin1_cma_reserved: linux,vdin1_cma {
			compatible = "shared-dma-pool";
			reusable;
			size = <0x0 0x20000000>;
			alignment = <0x0 0x00400000>;
			alloc-ranges = <0x0 0x0 0x0 0xe0000000>;
		};

		/* Vendor U-Boot hardcodes this node path during rsvmem check. */
		secmon_reserved: linux,secmon {
			compatible = "shared-dma-pool";
			no-map;
			size = <0x0 0x03400000>;
			alignment = <0x0 0x00400000>;
			alloc-ranges = <0x0 0x05000000 0x0 0x03400000>;
		};
	};

	partitions: partitions {
		parts = <1>;
		part-0 = <&rootfs>;

		rootfs: rootfs {
			pname = "rootfs";
			size = <0xffffffff 0xffffffff>;
			mask = <4>;
		};
	};

	secmon {
		compatible = "amlogic, secmon";
		memory-region = <&secmon_reserved>;
		in_base_func = <0x82000020>;
		out_base_func = <0x82000021>;
		inout_size_func = <0x8200002a>;
		reserve_mem_size = <0x03300000>;
	};

	codec_mm {
		compatible = "amlogic, codec, mm";
		memory-region = <&codec_mm_cma>;
		dev_name = "codec_mm";
		status = "okay";
	};

	canvas: canvas {
		compatible = "amlogic, meson, canvas";
		dev_name = "amlogic-canvas";
		status = "okay";
		reg = <0x0 0xfe036048 0x0 0x2000>;
	};

	meson_uvm {
		compatible = "amlogic, meson_uvm";
		status = "okay";
	};

	meson_videotunnel {
		compatible = "amlogic, meson_videotunnel";
		status = "okay";
	};

	video_composer {
		compatible = "amlogic, video_composer";
		dev_name = "video_composer";
		status = "okay";
	};

	amvideom: meson-amvideom {
		compatible = "amlogic, amvideom-t7";
		dev_name = "amvideom";
		status = "okay";
		interrupts = <GIC_SPI 197 IRQ_TYPE_EDGE_RISING>,
			     <GIC_SPI 194 IRQ_TYPE_EDGE_RISING>,
			     <GIC_SPI 82 IRQ_TYPE_EDGE_RISING>;
		interrupt-names = "vsync", "vsync_viu2", "vsync_viu3";
	};

	vpu_security {
		compatible = "amlogic, meson-t7, vpu_security";
		dev_name = "amlogic-vpu-security";
		status = "okay";
		interrupts = <GIC_SPI 220 IRQ_TYPE_EDGE_RISING>;
		interrupt-names = "vpu_security";
	};

	xtal: xtal-clk {
		compatible = "fixed-clock";
		clock-frequency = <24000000>;
		clock-output-names = "xtal";
		#clock-cells = <0>;
	};

	/* Temporary parent clocks until the full T7 SCMI/PLL map is safe to enable. */
	sys_clk: sys-clk {
		compatible = "fixed-clock";
		clock-frequency = <166666666>;
		clock-output-names = "sys";
		#clock-cells = <0>;
	};

	fixed_pll: fixed-pll-clk {
		compatible = "fixed-clock";
		clock-frequency = <2000000000>;
		clock-output-names = "fix";
		#clock-cells = <0>;
	};

	fdiv2: fdiv2-clk {
		compatible = "fixed-clock";
		clock-frequency = <1000000000>;
		clock-output-names = "fdiv2";
		#clock-cells = <0>;
	};

	fdiv2p5: fdiv2p5-clk {
		compatible = "fixed-clock";
		clock-frequency = <800000000>;
		clock-output-names = "fdiv2p5";
		#clock-cells = <0>;
	};

	fdiv3: fdiv3-clk {
		compatible = "fixed-clock";
		clock-frequency = <666666666>;
		clock-output-names = "fdiv3";
		#clock-cells = <0>;
	};

	fdiv4: fdiv4-clk {
		compatible = "fixed-clock";
		clock-frequency = <500000000>;
		clock-output-names = "fdiv4";
		#clock-cells = <0>;
	};

	fdiv5: fdiv5-clk {
		compatible = "fixed-clock";
		clock-frequency = <400000000>;
		clock-output-names = "fdiv5";
		#clock-cells = <0>;
	};

	fdiv7: fdiv7-clk {
		compatible = "fixed-clock";
		clock-frequency = <285714285>;
		clock-output-names = "fdiv7";
		#clock-cells = <0>;
	};

	hifi: hifi-clk {
		compatible = "fixed-clock";
		clock-frequency = <500000000>;
		clock-output-names = "hifi";
		#clock-cells = <0>;
	};

	gp0: gp0-clk {
		compatible = "fixed-clock";
		clock-frequency = <1000000000>;
		clock-output-names = "gp0";
		#clock-cells = <0>;
	};

	gp1: gp1-clk {
		compatible = "fixed-clock";
		clock-frequency = <1000000000>;
		clock-output-names = "gp1";
		#clock-cells = <0>;
	};

	mpll1: mpll1-clk {
		compatible = "fixed-clock";
		clock-frequency = <500000000>;
		clock-output-names = "mpll1";
		#clock-cells = <0>;
	};

	mpll2: mpll2-clk {
		compatible = "fixed-clock";
		clock-frequency = <500000000>;
		clock-output-names = "mpll2";
		#clock-cells = <0>;
	};

	mpll_50m: mpll-50m-clk {
		compatible = "fixed-clock";
		clock-frequency = <50000000>;
		clock-output-names = "mpll_50m";
		#clock-cells = <0>;
	};

	audio_hifi_pll: audio-hifi-pll-clk {
		compatible = "fixed-clock";
		clock-frequency = <491520000>;
		clock-output-names = "hifi_pll";
		#clock-cells = <0>;
	};

	audio_mpll0: audio-mpll0-clk {
		compatible = "fixed-clock";
		clock-frequency = <451584000>;
		clock-output-names = "mpll0";
		#clock-cells = <0>;
	};

	audio_mpll1_cd: audio-mpll1-cd-clk {
		compatible = "fixed-clock";
		clock-frequency = <451584000>;
		clock-output-names = "mpll1_cd";
		#clock-cells = <0>;
	};

	audio_mpll2: audio-mpll2-clk {
		compatible = "fixed-clock";
		clock-frequency = <491520000>;
		clock-output-names = "mpll2";
		#clock-cells = <0>;
	};

	audio_fclk_div4: audio-fclk-div4-clk {
		compatible = "fixed-clock";
		clock-frequency = <500000000>;
		clock-output-names = "fclk_div4";
		#clock-cells = <0>;
	};

	hdmirx_2m: hdmirx-2m-clk {
		compatible = "fixed-clock";
		clock-frequency = <2000000>;
		clock-output-names = "hdmirx_2m";
		#clock-cells = <0>;
	};

	hdmirx_5m: hdmirx-5m-clk {
		compatible = "fixed-clock";
		clock-frequency = <5000000>;
		clock-output-names = "hdmirx_5m";
		#clock-cells = <0>;
	};

	hdmirx_25m: hdmirx-25m-clk {
		compatible = "fixed-clock";
		clock-frequency = <25000000>;
		clock-output-names = "hdmirx_25m";
		#clock-cells = <0>;
	};

	ml_sound: auge-sound {
		compatible = "amlogic, auge-sound-card";
		aml-audio-card,name = "AML-AUGESOUND";
		avout_mute-gpios = <&gpio GPIOT_23 GPIO_ACTIVE_HIGH>;
		interrupts = <GIC_SPI 51 IRQ_TYPE_EDGE_RISING>;
		interrupt-names = "audio_exception64";
		#address-cells = <1>;
		#size-cells = <0>;
		status = "okay";

		aml-audio-card,dai-link@0 {
			reg = <0>;
			format = "i2s";
			mclk-fs = <256>;
			bitclock-master = <&tdmc>;
			frame-master = <&tdmc>;
			suffix-name = "alsaPORT-i2s4parser";

			cpu {
				sound-dai = <&tdmc>;
				dai-tdm-slot-tx-mask = <1 1>;
				dai-tdm-slot-rx-mask = <1 1>;
				dai-tdm-slot-num = <2>;
				dai-tdm-slot-width = <32>;
				system-clock-frequency = <12288000>;
			};

			codec {
				sound-dai = <&dummy_codec>;
			};
		};

		aml-audio-card,dai-link@1 {
			reg = <1>;
			mclk-fs = <128>;
			continuous-clock;
			suffix-name = "alsaPORT-spdif";

			cpu {
				sound-dai = <&spdifa>;
				system-clock-frequency = <6144000>;
			};

			codec {
				sound-dai = <&dummy_codec>;
			};
		};

		aml-audio-card,dai-link@2 {
			reg = <2>;
			format = "i2s";
			mclk-fs = <256>;
			continuous-clock;
			bitclock-master = <&tdmb>;
			frame-master = <&tdmb>;
			suffix-name = "alsaPORT-i2s-acodec";

			cpu {
				sound-dai = <&tdmb>;
				dai-tdm-slot-tx-mask = <1 1>;
				dai-tdm-slot-rx-mask = <1 1>;
				dai-tdm-slot-num = <2>;
				dai-tdm-slot-width = <32>;
				system-clock-frequency = <12288000>;
			};

			codec {
				sound-dai = <&acodec>;
			};
		};

		aml-audio-card,dai-link@3 {
			reg = <3>;
			mclk-fs = <128>;
			suffix-name = "alsaPORT-spdifb";

			cpu {
				sound-dai = <&spdifb>;
				system-clock-frequency = <6144000>;
			};

			codec {
				sound-dai = <&dummy_codec>;
			};
		};

	};

	vddao_3v3: regulator-vddao-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "VDDAO_3V3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
	};

	vdd_mali: regulator-vdd-mali {
		compatible = "regulator-fixed";
		regulator-name = "VDD_MALI";
		regulator-min-microvolt = <1150000>;
		regulator-max-microvolt = <1150000>;
		regulator-always-on;
	};

	vddio_1v8: regulator-vddio-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "VDDIO_1V8";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-always-on;
	};

	sdcard_power: regulator-sdcard-power {
		compatible = "regulator-fixed";
		regulator-name = "SDCARD_POWER";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpio = <&gpio GPIOD_11 GPIO_ACTIVE_LOW>;
		regulator-boot-on;
	};

	vddio_card: regulator-vddio-card {
		compatible = "regulator-gpio";
		regulator-name = "VDDIO_CARD";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpios = <&gpio GPIOD_9 GPIO_ACTIVE_HIGH>;
		gpios-states = <0>;
		states = <1800000 1>,
			 <3300000 0>;
		regulator-boot-on;
	};

	wifi_32k: wifi-32k-clock {
		compatible = "pwm-clock";
		#clock-cells = <0>;
		clock-frequency = <32768>;
		clock-output-names = "wifi_32k";
		pwms = <&pwm_ab 0 30518 0>;
	};

	wifi_pwrseq: wifi-pwrseq {
		compatible = "mmc-pwrseq-simple";
		clocks = <&wifi_32k>;
		clock-names = "ext_clock";
		reset-gpios = <&gpio GPIOX_6 GPIO_ACTIVE_LOW>;
		post-power-on-delay-ms = <200>;
	};

	usb_power: regulator-usb-power {
		compatible = "regulator-fixed";
		regulator-name = "USB_POWER";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		gpio = <&gpio GPIOH_4 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		regulator-boot-on;
		regulator-always-on;
	};

	otg_power: regulator-otg-power {
		compatible = "regulator-fixed";
		regulator-name = "OTG_POWER";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		gpio = <&gpio GPIOH_5 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		regulator-boot-on;
		regulator-always-on;
	};

};

&{/} {
	thermal-zones {
		a73_thermal: a73-thermal {
			polling-delay = <1000>;
			polling-delay-passive = <100>;
			thermal-sensors = <&a73_temp>;

			trips {
				a73_passive: a73-passive {
					temperature = <85000>;
					hysteresis = <2000>;
					type = "passive";
				};

				a73_hot: a73-hot {
					temperature = <95000>;
					hysteresis = <2000>;
					type = "hot";
				};

				a73_critical: a73-critical {
					temperature = <110000>;
					hysteresis = <2000>;
					type = "critical";
				};
			};
		};

		a53_thermal: a53-thermal {
			polling-delay = <1000>;
			polling-delay-passive = <100>;
			thermal-sensors = <&a53_temp>;

			trips {
				a53_passive: a53-passive {
					temperature = <85000>;
					hysteresis = <2000>;
					type = "passive";
				};

				a53_hot: a53-hot {
					temperature = <95000>;
					hysteresis = <2000>;
					type = "hot";
				};

				a53_critical: a53-critical {
					temperature = <110000>;
					hysteresis = <2000>;
					type = "critical";
				};
			};
		};
	};

	gpu: gpu@fe400000 {
		compatible = "amlogic,meson-t7-mali", "arm,mali-bifrost";
		reg = <0x0 0xfe400000 0x0 0x4000>;
		interrupt-parent = <&gic>;
		interrupts = <GIC_SPI 146 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 145 IRQ_TYPE_LEVEL_HIGH>,
			     <GIC_SPI 144 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "job", "mmu", "gpu";
		clocks = <&clkc_periphs CLKID_MALI>;
		mali-supply = <&vdd_mali>;
		operating-points-v2 = <&gpu_opp_table>;
		power-domains = <&pwrc PWRC_T7_MALI_TOP_ID>;
		resets = <&reset RESET_MALI_CAPB3>, <&reset RESET_MALI>;
		#cooling-cells = <2>;

		assigned-clocks = <&clkc_periphs CLKID_MALI_0_SEL>,
				  <&clkc_periphs CLKID_MALI_0>,
				  <&clkc_periphs CLKID_MALI>;
		assigned-clock-parents = <&fdiv2p5>,
					 <0>,
					 <&clkc_periphs CLKID_MALI_0>;
		assigned-clock-rates = <0>, <800000000>, <0>;
		status = "okay";
	};

	hdmirx: hdmirx {
		compatible = "amlogic, hdmirx_t7";
		status = "okay";
		pinctrl-names = "hdmirx_pins";
		pinctrl-0 = <&hdmirx_a_mux &hdmirx_b_mux &hdmirx_c_mux>;
		repeat = <0>;
		power-domains = <&pwrc PWRC_T7_HDMIRX_ID>;
		interrupts = <GIC_SPI 57 IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&mpll_50m>,
			 <&xtal>,
			 <&xtal>,
			 <&hdmirx_2m>,
			 <&hdmirx_5m>,
			 <&hdmirx_25m>,
			 <&xtal>,
			 <&fdiv4>,
			 <&fdiv5>;
		clock-names = "hdmirx_cfg_clk",
			      "cts_hdmirx_acr_ref_clk",
			      "cts_hdmirx_meter_clk",
			      "cts_hdmirx_2m_clk",
			      "cts_hdmirx_5m_clk",
			      "cts_hdmirx_hdcp2x_eclk",
			      "xtal",
			      "fclk_div4",
			      "fclk_div5";
		hdmirx_id = <0>;
		en_4k_2_2k = <0>;
		hpd_low_cec_off = <1>;
		arc_port = <1>;
		disable_port = <0x0>;
		/* Keep the 5.15 vendor register-map order. */
		reg = <0x0 0x0 0x0 0x0
		       0x0 0xff63c000 0x0 0x2000
		       0x0 0xffe0d000 0x0 0x2000
		       0x0 0x0 0x0 0x0
		       0x0 0x0 0x0 0x0
		       0x0 0x0 0x0 0x0
		       0x0 0xfe398000 0x0 0x18000
		       0x0 0xfe000000 0x0 0x1fff>;
	};

	vdin0: vdin0 {
		compatible = "amlogic, vdin-t7";
		dev_name = "vdin0";
		status = "okay";
		reserve-iomap = "true";
		flag_cma = <0x101>;
		cma_size = <280>;
		frame_buff_num = <10>;
		interrupts = <GIC_SPI 210 IRQ_TYPE_EDGE_RISING>,
			     <GIC_SPI 214 IRQ_TYPE_EDGE_RISING>;
		interrupt-names = "vsync_int",
				  "mif2_meta_wr_done_int";
		rdma-irq = <2>;
		clocks = <&fdiv5>, <&clkc_periphs CLKID_VDIN_MEAS_GATE>;
		clock-names = "fclk_div5", "cts_vdin_meas_clk";
		vdin_id = <0>;
		tv_bit_mode = <0x235>;
		afbce_bit_mode = <0x11>;
		v4l_support_en = <0>;
		v4l_vd_num = <70>;
		driver = "vdin_video";
		card = "mesont7";
		bus_info = "vdin0 v4l2";
		version = <0x20220120>;
		fe_ports = <0x00001001
			    0x00004000
			    0x00004001
			    0x00004002>;
		vdin_function_sel = <0x101>;
		double_write_en;
		urgent_en;
	};

	vdin1: vdin1 {
		compatible = "amlogic, vdin-t7";
		dev_name = "vdin1";
		status = "okay";
		reserve-iomap = "true";
		memory-region = <&vdin1_cma_reserved>;
		flag_cma = <0>;
		interrupts = <GIC_SPI 212 IRQ_TYPE_EDGE_RISING>;
		interrupt-names = "vsync_int";
		rdma-irq = <4>;
		vdin_id = <1>;
		tv_bit_mode = <0x15>;
		v4l_support_en = <0>;
		v4l_vd_num = <71>;
		driver = "vdin_video";
		card = "mesont7";
		bus_info = "vdin1 v4l2";
		version = <0x20220120>;
		fe_ports = <0x0000a002
			    0x0000a003
			    0x0000a004
			    0x0000a005
			    0x0000a006
			    0x0000a007
			    0x0000a008>;
		vdin_function_sel = <0x400>;
	};
};

&apb4 {
	clkc_periphs: clock-controller@0 {
		compatible = "amlogic,t7-peripherals-clkc";
		reg = <0x0 0x0 0x0 0x1c8>;
		#clock-cells = <1>;
		clocks = <&xtal>,
			 <&sys_clk>,
			 <&fixed_pll>,
			 <&fdiv2>,
			 <&fdiv2p5>,
			 <&fdiv3>,
			 <&fdiv4>,
			 <&fdiv5>,
			 <&fdiv7>,
			 <&hifi>,
			 <&gp0>,
			 <&gp1>,
			 <&mpll1>,
			 <&mpll2>;
		clock-names = "xtal",
			      "sys",
			      "fix",
			      "fdiv2",
			      "fdiv2p5",
			      "fdiv3",
			      "fdiv4",
			      "fdiv5",
			      "fdiv7",
			      "hifi",
			      "gp0",
			      "gp1",
			      "mpll1",
			      "mpll2";
	};

	uart_c: serial@7c000 {
		compatible = "amlogic,t7-uart", "amlogic,meson-s4-uart";
		reg = <0x0 0x7c000 0x0 0x18>;
		interrupts = <GIC_SPI 170 IRQ_TYPE_EDGE_RISING>;
		status = "disabled";
	};

	eth_phy: mdio-multiplexer@28000 {
		compatible = "amlogic,g12a-mdio-mux";
		reg = <0x0 0x28000 0x0 0xa4>;
		clocks = <&clkc_periphs CLKID_SYS_ETHPHY>,
			 <&xtal>,
			 <&mpll_50m>;
		clock-names = "pclk", "clkin0", "clkin1";
		mdio-parent-bus = <&mdio0>;
		#address-cells = <1>;
		#size-cells = <0>;

		ext_mdio: mdio@0 {
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <0>;

			external_phy: ethernet-phy@0 {
				reg = <0>;
				max-speed = <1000>;
				reset-assert-us = <20000>;
				reset-deassert-us = <50000>;
			};
		};
	};
};

&gpio {
	status_led_hog: status-led-hog {
		gpio-hog;
		gpios = <GPIOM_10 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "status-led";
	};
};

&periphs_pinctrl {
	eth_pins: eth-pins {
		mux {
			groups = "eth_mdio",
				 "eth_mdc",
				 "eth_rgmii_rx_clk",
				 "eth_rx_dv",
				 "eth_rxd0",
				 "eth_rxd1",
				 "eth_txen",
				 "eth_txd0",
				 "eth_txd1";
			function = "eth";
			bias-disable;
			drive-strength-microamp = <4000>;
		};
	};

	eth_rgmii_pins: eth-rgmii-pins {
		mux {
			groups = "eth_rxd2_rgmii",
				 "eth_rxd3_rgmii",
				 "eth_rgmii_tx_clk",
				 "eth_txd2_rgmii",
				 "eth_txd3_rgmii";
			function = "eth";
			bias-disable;
			drive-strength-microamp = <4000>;
		};
	};

	hdmirx_a_mux: hdmirx-a-mux {
		mux {
			groups = "hdmirx_a_hpd",
				 "hdmirx_a_det",
				 "hdmirx_a_sda",
				 "hdmirx_a_sck";
			function = "hdmirx_a";
		};
	};

	hdmirx_b_mux: hdmirx-b-mux {
		mux {
			groups = "hdmirx_b_hpd",
				 "hdmirx_b_det",
				 "hdmirx_b_sda",
				 "hdmirx_b_sck";
			function = "hdmirx_b";
		};
	};

	hdmirx_c_mux: hdmirx-c-mux {
		mux {
			groups = "hdmirx_c_hpd",
				 "hdmirx_c_det",
				 "hdmirx_c_sda",
				 "hdmirx_c_sck";
			function = "hdmirx_c";
		};
	};

	sdcard_pins: sdcard-pins {
		mux {
			groups = "sdcard_d0",
				 "sdcard_d1",
				 "sdcard_d2",
				 "sdcard_d3",
				 "sdcard_cmd";
			function = "sdcard";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};

		mux-clk {
			groups = "sdcard_clk";
			function = "sdcard";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};
	};

	sdcard_clk_gate_pins: sdcard-clk-gate-pins {
		mux {
			groups = "GPIOC_4";
			function = "gpio_periphs";
			bias-pull-down;
			drive-strength-microamp = <4000>;
		};
	};

	emmc_pins: emmc-pins {
		mux {
			groups = "emmc_nand_d0",
				 "emmc_nand_d1",
				 "emmc_nand_d2",
				 "emmc_nand_d3",
				 "emmc_nand_d4",
				 "emmc_nand_d5",
				 "emmc_nand_d6",
				 "emmc_nand_d7",
				 "emmc_cmd";
			function = "emmc";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};
	};

	emmc_clk_pins: emmc-clk-pins {
		mux {
			groups = "emmc_clk";
			function = "emmc";
			bias-disable;
			drive-strength-microamp = <4000>;
		};
	};

	emmc_ds_pins: emmc-ds-pins {
		mux {
			groups = "emmc_nand_ds";
			function = "emmc";
			bias-pull-down;
			drive-strength-microamp = <4000>;
		};
	};

	emmc_clk_gate_pins: emmc-clk-gate-pins {
		mux {
			groups = "GPIOB_8";
			function = "gpio_periphs";
			bias-pull-down;
			drive-strength-microamp = <4000>;
		};
	};

	sdio_pins: sdio-pins {
		mux {
			groups = "sdio_d0",
				 "sdio_d1",
				 "sdio_d2",
				 "sdio_d3",
				 "sdio_cmd";
			function = "sdio";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};

		mux-clk {
			groups = "sdio_clk";
			function = "sdio";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};
	};

	sdio_clk_gate_pins: sdio-clk-gate-pins {
		mux {
			groups = "GPIOX_4";
			function = "gpio_periphs";
			bias-pull-down;
			drive-strength-microamp = <4000>;
		};
	};

	uart_c_pins: uart-c-pins {
		mux {
			groups = "uart_c_tx",
				 "uart_c_rx",
				 "uart_c_cts",
				 "uart_c_rts";
			function = "uart_c";
			bias-disable;
		};
	};

	mclk_1_pins: mclk-1-pins {
		mux {
			groups = "mclk1";
			function = "mclk";
		};
	};

	tdm_b_pins: tdm-b-pins {
		mux {
			groups = "tdm_sclk1",
				 "tdm_fs1",
				 "tdm_d4",
				 "tdm_d5";
			function = "tdm";
		};
	};
};

&pinctrl_audio {
	tdm_d4_pins: tdm-d4-pins {
		mux {
			groups = "tdm_d4";
			function = "tdmoutb_lane0";
		};
	};

	tdm_d5_pins: tdm-d5-pins {
		mux {
			groups = "tdm_d5";
			function = "tdminb_lane0";
		};
	};

	tdmb_clk_pins: tdmb-clk-pins {
		mux {
			groups = "tdm_sclk1", "tdm_lrclk1";
			function = "tdm_clk_outb";
		};
	};
};

&{/soc} {
	a73_temp: temperature-sensor@fe020000 {
		compatible = "amlogic,t7-thermal";
		reg = <0x0 0xfe020000 0x0 0x50>;
		interrupts = <GIC_SPI 31 IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&clkc_periphs CLKID_TS>;
		assigned-clocks = <&clkc_periphs CLKID_TS>;
		assigned-clock-rates = <500000>;
		#thermal-sensor-cells = <0>;
		amlogic,thermal-sensor-id = <1>;
		secure-monitor = <&sm>;
	};

	a53_temp: temperature-sensor@fe022000 {
		compatible = "amlogic,t7-thermal";
		reg = <0x0 0xfe022000 0x0 0x50>;
		interrupts = <GIC_SPI 30 IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&clkc_periphs CLKID_TS>;
		assigned-clocks = <&clkc_periphs CLKID_TS>;
		assigned-clock-rates = <500000>;
		#thermal-sensor-cells = <0>;
		amlogic,thermal-sensor-id = <2>;
		secure-monitor = <&sm>;
	};

	ethmac: ethernet@fdc00000 {
		compatible = "amlogic,meson-g12a-dwmac",
			     "snps,dwmac-4.00",
			     "snps,dwmac";
		reg = <0x0 0xfdc00000 0x0 0x10000>,
		      <0x0 0xfe024000 0x0 0x8>;
		interrupts = <GIC_SPI 74 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "macirq";
		clocks = <&clkc_periphs CLKID_SYS_ETH>,
			 <&fdiv2>,
			 <&mpll2>;
		clock-names = "stmmaceth", "clkin0", "clkin1";
		power-domains = <&pwrc PWRC_T7_ETH_ID>;
		pinctrl-0 = <&eth_pins>, <&eth_rgmii_pins>;
		pinctrl-names = "default";
		phy-mode = "rgmii";
		phy-handle = <&external_phy>;
		amlogic,tx-delay-ns = <2>;
		rx-internal-delay-ps = <2000>;
		internal_phy = <2>;
		mc_val = <0x1621>;
		cali_val = <0xa0000>;
		rx-fifo-depth = <4096>;
		tx-fifo-depth = <2048>;
		status = "okay";

		mdio0: mdio {
			compatible = "snps,dwmac-mdio";
			#address-cells = <1>;
			#size-cells = <0>;
		};
	};

	usb2_phy0: phy@fe03c000 {
		compatible = "amlogic,g12a-usb2-phy";
		reg = <0x0 0xfe03c000 0x0 0x2000>;
		clocks = <&xtal>;
		clock-names = "xtal";
		resets = <&reset RESET_U2PHY20>;
		reset-names = "phy";
		power-domains = <&pwrc PWRC_T7_USB_COMB_ID>;
		phy-supply = <&usb_power>;
		#phy-cells = <0>;
	};

	usb2_phy1: phy@fe03e000 {
		compatible = "amlogic,g12a-usb2-phy";
		reg = <0x0 0xfe03e000 0x0 0x2000>;
		clocks = <&xtal>;
		clock-names = "xtal";
		resets = <&reset RESET_U2PHY21>;
		reset-names = "phy";
		power-domains = <&pwrc PWRC_T7_USB_COMB_ID>;
		phy-supply = <&otg_power>;
		#phy-cells = <0>;
	};

	usb: usb@fe03a000 {
		compatible = "amlogic,meson-g12a-usb-ctrl";
		reg = <0x0 0xfe03a000 0x0 0xa0>;
		interrupts = <GIC_SPI 129 IRQ_TYPE_EDGE_RISING>;
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		clocks = <&clkc_periphs CLKID_SYS_USB>;
		resets = <&reset RESET_USB>;
		power-domains = <&pwrc PWRC_T7_USB_COMB_ID>;

		dr_mode = "host";

		phys = <&usb2_phy0>, <&usb2_phy1>;
		phy-names = "usb2-phy0", "usb2-phy1";

		xhci2: usb@fdd00000 {
			compatible = "amlogic,t7-crg-xhci", "generic-xhci";
			reg = <0x0 0xfdd00000 0x0 0x8000>;
			interrupts = <GIC_SPI 131 IRQ_TYPE_EDGE_RISING>;
			clocks = <&clkc_periphs CLKID_SYS_USB>;
			clock-names = "core";
			dr_mode = "host";
			usb2-lpm-disable;
		};

		xhci3: usb@fde00000 {
			compatible = "amlogic,t7-crg-xhci", "generic-xhci";
			reg = <0x0 0xfde00000 0x0 0x8000>;
			interrupts = <GIC_SPI 130 IRQ_TYPE_EDGE_RISING>;
			clocks = <&clkc_periphs CLKID_SYS_USB>;
			clock-names = "core";
			dr_mode = "host";
			usb2-lpm-disable;
		};
	};

	sd_emmc_a: mmc@fe088000 {
		compatible = "amlogic,t7-mmc", "amlogic,meson-axg-mmc";
		reg = <0x0 0xfe088000 0x0 0x800>;
		interrupts = <GIC_SPI 176 IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&clkc_periphs CLKID_SYS_SD_EMMC_A>,
			 <&clkc_periphs CLKID_SD_EMMC_A>,
			 <&fdiv2>;
		clock-names = "core", "clkin0", "clkin1";
		resets = <&reset RESET_SD_EMMC_A>;
		power-domains = <&pwrc PWRC_T7_SDIO_A_ID>;
		pinctrl-0 = <&sdio_pins>;
		pinctrl-1 = <&sdio_clk_gate_pins>;
		pinctrl-names = "default", "clk-gate";
		bus-width = <4>;
		cap-sd-highspeed;
		cap-sdio-irq;
		max-frequency = <50000000>;
		non-removable;
		disable-wp;
		keep-power-in-suspend;
		no-mmc;
		no-sd;
		mmc-pwrseq = <&wifi_pwrseq>;
		vmmc-supply = <&vddao_3v3>;
		vqmmc-supply = <&vddio_1v8>;
		#address-cells = <1>;
		#size-cells = <0>;
		status = "okay";

		brcmf: wifi@1 {
			reg = <1>;
			compatible = "brcm,bcm4359-fmac", "brcm,bcm4329-fmac";
			brcm,board-type = "ap6398s";
			clocks = <&wifi_32k>;
			clock-names = "lpo";
		};
	};

	sd_emmc_b: mmc@fe08a000 {
		compatible = "amlogic,t7-mmc", "amlogic,meson-axg-mmc";
		reg = <0x0 0xfe08a000 0x0 0x800>;
		interrupts = <GIC_SPI 177 IRQ_TYPE_EDGE_RISING>;
		clocks = <&clkc_periphs CLKID_SYS_SD_EMMC_B>,
			 <&clkc_periphs CLKID_SD_EMMC_B>,
			 <&fdiv2>;
		clock-names = "core", "clkin0", "clkin1";
		resets = <&reset RESET_SD_EMMC_B>;
		power-domains = <&pwrc PWRC_T7_SDIO_B_ID>;
		pinctrl-0 = <&sdcard_pins>;
		pinctrl-1 = <&sdcard_clk_gate_pins>;
		pinctrl-names = "default", "clk-gate";
		bus-width = <4>;
		cap-sd-highspeed;
		max-frequency = <50000000>;
		assigned-clocks = <&clkc_periphs CLKID_SD_EMMC_B>;
		assigned-clock-rates = <24000000>;
		disable-wp;
		no-mmc;
		no-sdio;
		cd-gpios = <&gpio GPIOC_6 GPIO_ACTIVE_LOW>;
		vmmc-supply = <&sdcard_power>;
		vqmmc-supply = <&vddio_card>;
		status = "okay";
	};

	sd_emmc_c: mmc@fe08c000 {
		compatible = "amlogic,t7-mmc", "amlogic,meson-axg-mmc";
		reg = <0x0 0xfe08c000 0x0 0x800>;
		interrupts = <GIC_SPI 178 IRQ_TYPE_EDGE_RISING>;
		clocks = <&clkc_periphs CLKID_SYS_SD_EMMC_C>,
			 <&clkc_periphs CLKID_SD_EMMC_C>,
			 <&fdiv2>;
		clock-names = "core", "clkin0", "clkin1";
		resets = <&reset RESET_SD_EMMC_C>;
		power-domains = <&pwrc PWRC_T7_EMMC_ID>;
		pinctrl-0 = <&emmc_pins>, <&emmc_clk_pins>, <&emmc_ds_pins>;
		pinctrl-1 = <&emmc_clk_gate_pins>;
		pinctrl-names = "default", "clk-gate";
		bus-width = <8>;
		cap-mmc-highspeed;
		max-frequency = <50000000>;
		assigned-clocks = <&clkc_periphs CLKID_SD_EMMC_C>;
		assigned-clock-rates = <24000000>;
		non-removable;
		disable-wp;
		no-sd;
		no-sdio;
		vmmc-supply = <&vddao_3v3>;
		vqmmc-supply = <&vddio_1v8>;
		status = "okay";
	};
};

&audiobus {
	tdmb: tdm@1 {
		compatible = "amlogic, t7-snd-tdmb";
		#sound-dai-cells = <0>;
		dai-tdm-lane-slot-mask-in = <1 0 0 0>;
		dai-tdm-lane-slot-mask-out = <1 0 0 0>;
		dai-tdm-clk-sel = <1>;
		clocks = <&clkaudio CLKID_AUDIO_MCLK_B>,
			 <&clkaudio CLKID_AUDIO_MCLK_PAD1>,
			 <&audio_hifi_pll>,
			 <&audio_mpll1_cd>,
			 <&clkaudio CLKID_AUDIO_GATE_TDMINB>,
			 <&clkaudio CLKID_AUDIO_GATE_TDMOUTB>;
		clock-names = "mclk", "mclk_pad", "clk_srcpll", "clk_src_cd",
			      "gate_in", "gate_out";
		src-clk-freq = <491520000>;
		pinctrl-names = "tdm_pins";
		pinctrl-0 = <&mclk_1_pins>, <&tdm_b_pins>, <&tdm_d4_pins>,
			    <&tdm_d5_pins>, <&tdmb_clk_pins>;
		samesource_sel = <3>;
		tdmin-src-name = "acodec_adc";
		amlogic,playback-48k-only;
		amlogic,frddr-warmup-once;
		start_clk_enable = <1>;
		ctrl_gain = <1>;
		clk_tuning_enable = <1>;
		status = "okay";

		Channel_Mask {
			Spdif_samesource_Channel_Mask = "i2s_0/1";
		};
	};

	tdmc: tdm@2 {
		compatible = "amlogic, t7-snd-tdmc";
		#sound-dai-cells = <0>;
		dai-tdm-lane-slot-mask-in = <1 1 1 1>;
		dai-tdm-lane-slot-mask-out = <1 1 1 1>;
		dai-tdm-clk-sel = <2>;
		clocks = <&clkaudio CLKID_AUDIO_MCLK_C>,
			 <&audio_hifi_pll>,
			 <&audio_mpll2>,
			 <&clkaudio CLKID_AUDIO_GATE_TDMINC>,
			 <&clkaudio CLKID_AUDIO_GATE_TDMOUTC>;
		clock-names = "mclk", "clk_srcpll", "clk_src_cd",
			      "gate_in", "gate_out";
		src-clk-freq = <491520000>;
		tdmin-src-name = "hdmirx";
		i2s2hdmi = <1>;
		suspend-clk-off = <1>;
		amlogic,playback-48k-only;
		amlogic,frddr-warmup-once;
		status = "okay";
	};

	spdifa: spdif@0 {
		compatible = "amlogic, tm2-revb-snd-spdif-a";
		#sound-dai-cells = <0>;
		clocks = <&audio_hifi_pll>,
			 <&audio_mpll0>,
			 <&audio_fclk_div4>,
			 <&clkaudio CLKID_AUDIO_GATE_SPDIFIN>,
			 <&clkaudio CLKID_AUDIO_GATE_SPDIFOUT_A>,
			 <&clkaudio CLKID_AUDIO_SPDIFIN>,
			 <&clkaudio CLKID_AUDIO_SPDIFOUT_A>;
		clock-names = "sysclk", "clk_src_cd", "fixed_clk",
			      "gate_spdifin", "gate_spdifout",
			      "clk_spdifin", "clk_spdifout";
		src-clk-freq = <491520000>;
		interrupts = <GIC_SPI 35 IRQ_TYPE_EDGE_RISING>;
		interrupt-names = "irq_spdifin";
		suspend-clk-off = <1>;
		clk_tuning_enable = <1>;
		status = "okay";
	};

	spdifb: spdif@1 {
		compatible = "amlogic, tm2-revb-snd-spdif-b";
		#sound-dai-cells = <0>;
		clocks = <&audio_hifi_pll>,
			 <&audio_mpll2>,
			 <&clkaudio CLKID_AUDIO_GATE_SPDIFOUT_B>,
			 <&clkaudio CLKID_AUDIO_SPDIFOUT_B>;
		clock-names = "sysclk", "clk_src_cd",
			      "gate_spdifout", "clk_spdifout";
		suspend-clk-off = <1>;
		src-clk-freq = <491520000>;
		status = "okay";
	};
};

&acodec {
	dat0_ch_sel = <0>;
};

&amlvecm {
	status = "okay";
	gamma_en = <0>;
	wb_en = <0>;
	cm_en = <0>;
	wb_sel = <0>;
	vlock_en = <0>;
	vlock_mode = <0x8>;
	vlock_pll_m_limit = <1>;
	vlock_line_limit = <2>;
	vrr_priority = <1>;
};

&drm_subsystem {
	status = "okay";
	memory-region = <&logo_reserved>;
	crtc_masks = <1 7 1>;
	dummyl_from_hdmitx = /bits/ 8 <1>;
};

&drm_vpu {
	status = "okay";
};

&vpu {
	status = "okay";
};

&amhdmitx {
	repeater_tx = <0>;
	enc_idx = <2>;
	vrr_type = <1>;
	hdmi_repeater = <1>;
	hdcp_ctl_lvl = <1>;
	max_refreshrate = <240>;
	status = "okay";
};

&pwm_ab {
	pinctrl-0 = <&pwm_a_pins>;
	pinctrl-names = "default";
};

&uart_a {
	status = "okay";
	clocks = <&xtal>, <&xtal>, <&xtal>;
	clock-names = "xtal", "pclk", "baud";
};

&uart_c {
	status = "okay";
	uart-has-rtscts;
	pinctrl-0 = <&uart_c_pins>;
	pinctrl-names = "default";
	clocks = <&xtal>, <&clkc_periphs CLKID_SYS_UART_C>,
		 <&xtal>;
	clock-names = "xtal", "pclk", "baud";
	fifo-size = <64>;

	bluetooth {
		compatible = "brcm,bcm4329-bt";
		shutdown-gpios = <&gpio GPIOX_17 GPIO_ACTIVE_HIGH>;
		max-speed = <2000000>;
	};
};
